# Copy to `.env` and fill in real values. Never commit `.env`.

# ---- PostgreSQL ----
POSTGRES_DB=concord
POSTGRES_USER=concord
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Used by sqlx-cli for migrations and (later) by the server at runtime.
# Construct from the POSTGRES_* values above — don't paste a real password
# into a template that ships in git. `<POSTGRES_PASSWORD>` is a placeholder.
# DATABASE_URL=postgres://concord:<POSTGRES_PASSWORD>@localhost:5432/concord

# ---- Redis ----
REDIS_PASSWORD=change-me
REDIS_PORT=6379

# ---- Application ----
# The vars below are read by the server (lands in #40); docker-compose does not
# consume them yet.

# Used by the server to sign session JWTs. Generate with: `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-string

# ---- OAuth providers ----
# Register apps and paste the client credentials here.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/auth/google/callback

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/oauth/github/callback
